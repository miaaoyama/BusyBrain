ASI1_API_KEY=your_asi_one_api_key

# Browserbase powers real venue search/fetch and the Stagehand fallback.
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_browserbase_project_id

# Optional durable Pika CDN URL for the cartoon meetup invitation shown in Streamlit.
# This is an output URL, not a secret.
PIKA_INVITE_VIDEO_URL=

# Set these once before publishing. Changing a seed changes its agent address.
BUSY_BRAIN_ORCHESTRATOR_SEED=replace_with_a_long_private_random_value
BUSY_BRAIN_STUDY_SEED=replace_with_a_different_private_random_value
BUSY_BRAIN_CALENDAR_SEED=replace_with_a_different_private_random_value
BUSY_BRAIN_WELLNESS_SEED=replace_with_a_different_private_random_value
